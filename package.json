{
    "name": "campinasfighters",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "build": "next build",
        "dev": "next dev",
        "vercel": "next build",
        "start": "next start",
        "lint": "eslint .",
        "next:update": "bun add next@latest react@latest react-dom@latest eslint-config-next@latest",
        "commit": "git pull && bun update && bun getSecurity.ts && bun run vercel && read -p 'Descriptions\n Commit: ' message && git add . && echo -n \"$message - \" && node getTime.js | xargs -I {} git commit -m \"$message - {}\" && git push",
        "clean": "rm -rf node_modules && bun install"
    },
    "dependencies": {
        "@wterm/dom": "^0.1.9",
        "@wterm/react": "^0.1.9",
        "dayjs": "^1.11.21",
        "eslint-config-next": "^16.2.6",
        "feed": "^5.2.1",
        "framer-motion": "^12.40.0",
        "gray-matter": "^4.0.3",
        "jspdf": "^4.2.1",
        "jspdf-autotable": "^5.0.8",
        "lucide-react": "^1.17.0",
        "marked": "^16.4.2",
        "next": "^16.2.6",
        "next-seo": "^6.8.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "sonner": "^2.0.7",
        "styled-components": "^6.4.2"
    },
    "devDependencies": {
        "@types/node": "^20.19.41",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "baseline-browser-mapping": "^2.10.33",
        "typescript": "^5.9.3"
    }
}
